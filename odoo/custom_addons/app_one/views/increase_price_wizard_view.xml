<odoo>
     <record id="increase_price_wizard_form_view" model="ir.ui.view">
        <field name="name">increase price wizard view form</field>
        <field name="model">increase.price.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                        <group>
                            <field name="percentage"/>

                        </group>
                    <footer>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                        <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
        <record id="increase_price_wizard_action" model="ir.actions.act_window">
        <field name="name">Increase Price</field>
        <field name="res_model">increase.price.wizard</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>
</odoo>