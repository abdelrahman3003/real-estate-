<odoo>
    <record id="property_view_tree" model="ir.ui.view">
        <field name="name">property tree</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <tree class="custom_header" decoration-danger="(is_late)">
                <field name="name"/>
                <field name="owner_id"/>
                <field name="is_late" invisible="1"/>
                <field name="postcode"/>
                <field name="date_availability"/>
                <field name="selling_price"/>
                <field name="garden"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
                <field name="leaves"/>
                <field name="garage"/>
                <field name="active"/>
            </tree>
        </field>
    </record>
    <record id="property_view_form" model="ir.ui.view">
        <field name="name">property form</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="action" type="object" class="btn-primary" string="Action"
                        />
                        <button name="action_draft" type="object" class="btn-primary" string="Set to draft"
                                invisible="state in ('draft','closed')"
                        />
                        <button name="action_pending" type="object" class="btn-secondary" string="pending"
                                invisible="state !='draft'"
                        />
                        <button name="action_sold" type="object" class="btn-success" string="sold"
                                invisible="state !='pending'"
                        />
                        <field name="state" widget="statusbar"/>


                    </header>
                    <div class="oe_title">
                        <label for="ref"/>
                        <h1>
                            <field name="ref"/>
                        </h1>
                        <label for="name"/>
                        <h3>
                            <field name="name" readonly="state=='closed'"/>
                        </h3>
                    </div>
                    <group>
                        <group string="General Info">
                            <field name="postcode" readonly="state=='closed'"/>
                            <field name="create_time" readonly="1"/>
                            <field name="date_availability" readonly="state=='closed'"/>
                            <field name="expected_selling_date" readonly="state=='closed'"/>
                            <field name="is_late" invisible="1" readonly="state=='closed'"/>
                            <field name="expected_price" readonly="state=='closed'"/>
                            <field name="selling_price" readonly="state=='closed'"/>
                            <field name="diff" readonly="state=='closed'"/>
                            <field name="bedrooms" readonly="state=='closed'"/>
                            <field name="leaves" readonly="state=='closed'"/>
                            <field name="facades" readonly="state=='closed'"/>
                            <field name="active" readonly="state=='closed'"/>
                        </group>
                        <group string="Addition Info">
                            <field name="owner_id" readonly="state=='closed'"/>
                            <field name="owner_address" readonly="state=='closed'"/>
                            <field name="garage" readonly="state=='closed'"/>
                            <field name="garden" readonly="state=='closed'"/>
                            <field name="garden_area" readonly="state=='closed'"/>
                            <field name="garden_operator" readonly="state=='closed'"/>
                            <field name="tag_ids" widget="many2many_tags" readonly="state=='closed'"/>
                        </group>

                    </group>
                    <group>
                        <field name="description" required="1"/>
                    </group>
                    <notebook>
                        <page string="Bedrooms">
                            <field name="bedrooms_ids" readonly="state=='closed'">
                                <tree editable="bottom" class="o_ltr">
                                    <field name="description"/>
                                    <field name="area"/>

                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="property_view_search" model="ir.ui.view">
        <field name="name">property search</field>
        <field name="model">property</field>
        <field name="arch" type="xml">
            <search>
                <field name="postcode"/>
                <field name="name"/>
                <field name="active"/>
                <filter name="is_garden" string="Garden" domain="[('garden','=',True)]"/>
                <filter name="is_garage" string="Garage" domain="[('garage','=',True)]"/>
                <filter name="group_garden" string="Garden" context="{'group_by':'garden'}"/>
            </search>
        </field>
    </record>
    <record id="property_closed_action_server" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action=records.action_closed()
        </field>
    </record>
    <record id="property_change_state_action_server" model="ir.actions.server">
        <field name="name">Change State</field>
        <field name="model_id" ref="model_property"/>
        <field name="binding_model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            action=records.action_open_change_state()
        </field>
    </record>
    <record id="check_selling_date_cron" model="ir.cron">
        <field name="name">Property:check selling date</field>
        <field name="model_id" ref="model_property"/>
        <field name="state">code</field>
        <field name="code">
            model.check_expected_selling_date()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>

    </record>
    <record id="property_action" model="ir.actions.act_window">
        <field name="name">Properties Action</field>
        <field name="res_model">property</field>
    </record>

    <menuitem id="properties_menu_item"
              name="Properties"
              parent="properties_menu"
              action="property_action"/>

</odoo>