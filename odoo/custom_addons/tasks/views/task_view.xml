<odoo>

    <record id="task_view_tree" model="ir.ui.view">
        <field name="name">task tree</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <tree  decoration-danger="(is_late)">
                <field name="title"/>
                <field name="status"/>
                <field name="assign_to"/>
                <field name="date_only"/>
                <field name="is_late" invisible="1"/>
            </tree>
        </field>
    </record>
    <record id="task_view_form" model="ir.ui.view">
        <field name="name">task form</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form string="Task">
                <sheet>
                    <div class="oe_title">
                        <label for="title"/>
                        <h1>
                            <field name="title" placeholder="Enter task title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="status"/>
                            <field name="description" placeholder="Task description..."/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="assign_to"/>
                            <field name="estimated_time"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Timesheets" readonly="status=='completed'">
                            <field name="timesheet_ids">
                                <tree editable="bottom">
                                    <field name="date" readonly="1"/>
                                    <field name="user_id" readonly="1"/>
                                    <field name="description"/>
                                    <field name="hours"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="property_view_search" model="ir.ui.view">
        <field name="name">task search</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search>
                <field name="title"/>
                <filter string="New" name="new" domain="[('status','=','new')]"/>
                <filter string="In Progress" name="in_progress" domain="[('status','=','in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                <filter string="Group by Status" name="group_status" context="{'group_by':'status'}"/>
                <filter string="Group by Date" name="group_date" context="{'group_by':'create_date'}"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <record id="task_closed_action_server" model="ir.actions.server">
        <field name="name">Closed</field>
        <field name="model_id" ref="model_task"/>
        <field name="binding_model_id" ref="model_task"/>
        <field name="state">code</field>
        <field name="code">
            action=records.action_closed()
        </field>
    </record>

    <record id="check_task_date_cron" model="ir.cron">
        <field name="name">Task Deadline</field>
        <field name="model_id" ref="model_task"/>
        <field name="state">code</field>
        <field name="code">
            model.check_task_deadline_date()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="task_action" model="ir.actions.act_window">
        <field name="name">Task Action</field>
        <field name="res_model">task</field>
    </record>
    <menuitem id="tasks_menu_item"
              name="All Task"
              parent="tasks_menu"
              action="task_action"/>
</odoo>