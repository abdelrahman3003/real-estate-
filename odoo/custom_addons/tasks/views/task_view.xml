<odoo>

    <record id="task_view_tree" model="ir.ui.view">
        <field name="name">task tree</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <tree>
                <field name="title"/>
                <field name="status"/>
               <field name="assign_to"/>
               <field name="date_only"/>

            </tree>
        </field>
    </record>
<record id="task_view_form" model="ir.ui.view">
    <field name="name">task form</field>
    <field name="model">task</field>
    <field name="arch" type="xml">
        <form string="Task">
            <sheet>

                <div class="oe_title">
                    <label for="title"/>
                    <h1>
                        <field name="title" placeholder="Enter task title"/>
                    </h1>
                </div>

                <group>
                    <group >
                        <field name="status"/>
                        <field name="description" placeholder="Task description..."/>
                    </group>

                    <group>
                        <field name="create_date" readonly="1"/>
                        <field name="assign_to"/>
                    </group>
                </group>

            </sheet>
        </form>
    </field>
    </record>
     <record id="property_view_search" model="ir.ui.view">
        <field name="name">task search</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search>
          <field name="title"/>
            <filter string="New" name="new" domain="[('status','=','new')]"/>
            <filter string="In Progress" name="in_progress" domain="[('status','=','in_progress')]"/>
            <filter string="Completed" name="completed" domain="[('status','=','completed')]"/>
                <filter string="Group by Status" name="group_status" context="{'group_by':'status'}"/>
            <filter string="Group by Date" name="group_date" context="{'group_by':'create_date'}"/>
            </search>
        </field>
    </record>
    <record id="task_action" model="ir.actions.act_window">
        <field name="name">Task Action</field>
        <field name="res_model">task</field>
    </record>
    <menuitem id="tasks_menu_item"
              name="All Task"
              parent="tasks_menu"
              action="task_action"/>
</odoo>